			"item": [
				{
					"name": "Create Sale — Success",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"pm.test('Response contains sale data', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('sale_code');",
									"    pm.expect(jsonData.data).to.have.property('customer_id');",
									"    pm.expect(jsonData.data).to.have.property('total_sale');",
									"    pm.expect(jsonData.data).to.have.property('total_vat');",
									"    pm.expect(jsonData.data).to.have.property('total_with_vat');",
									"    pm.expect(jsonData.data).to.have.property('details');",
									"});",
									"",
									"pm.test('Sale code starts with V', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.sale_code).to.match(/^V\\d{3}$/);",
									"});",
									"",
									"pm.test('Details array has correct length', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.details).to.be.an('array').with.lengthOf(2);",
									"});",
									"",
									"pm.test('VAT calculation is correct', function () {",
									"    var jsonData = pm.response.json();",
									"    var d = jsonData.data;",
									"    pm.expect(Number(d.total_sale)).to.equal(17000);",
									"    pm.expect(Number(d.total_vat)).to.equal(3230);",
									"    pm.expect(Number(d.total_with_vat)).to.equal(20230);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "X-Internal", "value": "true" },
							{ "key": "X-User-Id", "value": "12345678" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"customer_id\": \"11111111\",\n  \"details\": [\n    {\n      \"product_code\": \"1001\",\n      \"product_name\": \"Manzanas Rojas\",\n      \"quantity\": 2,\n      \"unit_price\": 4000,\n      \"vat_rate\": 19\n    },\n    {\n      \"product_code\": \"1002\",\n      \"product_name\": \"Plátanos\",\n      \"quantity\": 3,\n      \"unit_price\": 3000,\n      \"vat_rate\": 19\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/sales/save",
							"host": ["{{base_url}}"],
							"path": ["sales", "save"]
						},
						"description": "## Create Sale — Success (SP4-QA-08)\n\nCreates a new sale with line items, automatic VAT calculation, and consecutive sale code generation.\n\n### Request Body\n| Field | Type | Required | Description |\n|---|---|---|---|\n| customer_id | string | Yes | Customer cedula |\n| details | array | Yes | 1-3 product line items |\n| details[].product_code | string | Yes | Product code |\n| details[].product_name | string | Yes | Product name |\n| details[].quantity | number | Yes | Quantity |\n| details[].unit_price | number | Yes | Unit price |\n| details[].vat_rate | number | Yes | VAT rate percentage |\n\n### Headers\n- `X-User-Id` — injected by gateway, identifies the seller\n\n### Calculations\n- `line_total = unit_price * quantity`\n- `line_vat = line_total * (vat_rate / 100)`\n- `total_sale = sum(line_total)`\n- `total_vat = sum(line_vat)`\n- `total_with_vat = total_sale + total_vat`\n\n### Response\n- **201 Created** — Sale created with calculated totals"
					},
					"response": [
						{
							"name": "201 — Sale Created",
							"originalRequest": {
								"method": "POST",
								"header": [
									{ "key": "Content-Type", "value": "application/json" },
									{ "key": "X-Internal", "value": "true" },
									{ "key": "X-User-Id", "value": "12345678" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"customer_id\": \"11111111\",\n  \"details\": [\n    {\n      \"product_code\": \"1001\",\n      \"product_name\": \"Manzanas Rojas\",\n      \"quantity\": 2,\n      \"unit_price\": 4000,\n      \"vat_rate\": 19\n    },\n    {\n      \"product_code\": \"1002\",\n      \"product_name\": \"Plátanos\",\n      \"quantity\": 3,\n      \"unit_price\": 3000,\n      \"vat_rate\": 19\n    }\n  ]\n}"
								},
								"url": {
									"raw": "{{base_url}}/sales/save",
									"host": ["{{base_url}}"],
									"path": ["sales", "save"]
								}
							},
							"status": "Created",
							"code": 201,
							"_postman_previewlanguage": "json",
							"header": [
								{ "key": "Content-Type", "value": "application/json; charset=utf-8" }
							],
							"body": "{\n  \"success\": true,\n  \"data\": {\n    \"sale_code\": \"V001\",\n    \"customer_id\": \"11111111\",\n    \"user_id\": \"12345678\",\n    \"total_sale\": 17000.00,\n    \"total_vat\": 3230.00,\n    \"total_with_vat\": 20230.00,\n    \"created_at\": \"2024-01-01T00:00:00.000Z\",\n    \"details\": [\n      {\n        \"product_code\": \"1001\",\n        \"product_name\": \"Manzanas Rojas\",\n        \"quantity\": 2,\n        \"unit_price\": 4000.00,\n        \"vat_rate\": 19.00,\n        \"line_total\": 8000.00,\n        \"line_vat\": 1520.00\n      },\n      {\n        \"product_code\": \"1002\",\n        \"product_name\": \"Plátanos\",\n        \"quantity\": 3,\n        \"unit_price\": 3000.00,\n        \"vat_rate\": 19.00,\n        \"line_total\": 9000.00,\n        \"line_vat\": 1710.00\n      }\n    ]\n  },\n  \"error\": null\n}"
						}
					]
