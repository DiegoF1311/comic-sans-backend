		{
			"key": "base_url",
			"value": "http://localhost:3005",
			"type": "string",
			"description": "Base URL of the sales-service (direct access)"
		},
		{
			"key": "gateway_url",
			"value": "http://localhost:8080",
			"type": "string",
			"description": "Base URL of the API Gateway (production entry point)"
		}
	],
