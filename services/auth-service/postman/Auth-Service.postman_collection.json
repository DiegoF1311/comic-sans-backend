				{
					"name": "Login — Success",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"pm.test('Response contains token', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('token');",
									"    pm.expect(jsonData.data.token).to.be.a('string');",
									"    pm.expect(jsonData.data.token.length).to.be.greaterThan(0);",
									"});",
									"",
									"pm.test('Token is a valid JWT format (3 parts)', function () {",
									"    var jsonData = pm.response.json();",
									"    var parts = jsonData.data.token.split('.');",
									"    pm.expect(parts.length).to.equal(3);",
									"});",
									"",
									"// Store token for use in other requests",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('auth_token', jsonData.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
