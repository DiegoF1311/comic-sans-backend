		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"pm.test('Response contains token', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('token');",
									"});",
									"",
									"// Auto-save token for subsequent requests",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('auth_token', jsonData.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admininicial\",\n  \"password\": \"admin123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "## Login via Gateway\n\nAuthenticates a user through the gateway. This route does **not** require JWT validation.\n\nThe returned token is automatically saved to the `auth_token` collection variable for use in protected endpoints.\n\n### Prerequisites\n- **auth-service** and **user-service** must be running\n\n### Request Body\n| Field | Type | Required |\n|---|---|---|\n| username | string | Yes |\n| password | string | Yes |"
					},
					"response": [
						{
							"name": "200 — Login Successful",
							"originalRequest": {
								"method": "POST",
								"header": [
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"username\": \"admininicial\",\n  \"password\": \"admin123456\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/auth/login",
									"host": ["{{base_url}}"],
									"path": ["api", "auth", "login"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{ "key": "Content-Type", "value": "application/json; charset=utf-8" }
							],
							"body": "{\n  \"success\": true,\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n  },\n  \"error\": null\n}"
						}
					]
				},
				{
					"name": "Protected Route — No Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 401', function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test('Response has success false', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.false;",
									"});",
									"",
									"pm.test('Error message indicates token required', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.error).to.equal('Token required');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users/list",
							"host": ["{{base_url}}"],
							"path": ["api", "users", "list"]
						},
						"description": "## Protected Route — No Token\n\nAttempts to access a protected route without providing a JWT.\n\n### Expected Behavior\n- Returns **401 Unauthorized** with `\"Token required\"`"
					},
					"response": [
						{
							"name": "401 — Token Required",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/api/users/list",
									"host": ["{{base_url}}"],
									"path": ["api", "users", "list"]
								}
							},
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"header": [
								{ "key": "Content-Type", "value": "application/json; charset=utf-8" }
							],
							"body": "{\n  \"success\": false,\n  \"data\": null,\n  \"error\": \"Token required\"\n}"
						}
					]
				},
				{
					"name": "Protected Route — Invalid Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 401', function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test('Error message indicates invalid token', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.error).to.equal('Invalid or expired token');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer invalid.token.here"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/users/list",
							"host": ["{{base_url}}"],
							"path": ["api", "users", "list"]
						},
						"description": "## Protected Route — Invalid Token\n\nAttempts to access a protected route with an invalid JWT.\n\n### Expected Behavior\n- Returns **401 Unauthorized** with `\"Invalid or expired token\"`"
					},
					"response": [
						{
							"name": "401 — Invalid Token",
							"originalRequest": {
								"method": "GET",
								"header": [
									{ "key": "Authorization", "value": "Bearer invalid.token.here" }
								],
								"url": {
									"raw": "{{base_url}}/api/users/list",
									"host": ["{{base_url}}"],
									"path": ["api", "users", "list"]
								}
							},
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"header": [
								{ "key": "Content-Type", "value": "application/json; charset=utf-8" }
							],
							"body": "{\n  \"success\": false,\n  \"data\": null,\n  \"error\": \"Invalid or expired token\"\n}"
						}
					]
				}
