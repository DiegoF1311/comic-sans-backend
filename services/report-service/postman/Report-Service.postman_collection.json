				{
					"name": "Sales By Customer Report — With Data",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"pm.test('Data is an array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.be.an('array');",
									"});",
									"",
									"pm.test('Each item has required fields', function () {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data.length > 0) {",
									"        var item = jsonData.data[0];",
									"        pm.expect(item).to.have.property('customer_id');",
									"        pm.expect(item).to.have.property('full_name');",
									"        pm.expect(item).to.have.property('total_purchases');",
									"    }",
									"});",
									"",
									"pm.test('Only customers with purchases are included', function () {",
									"    var jsonData = pm.response.json();",
									"    jsonData.data.forEach(function(item) {",
									"        pm.expect(Number(item.total_purchases)).to.be.greaterThan(0);",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "X-Internal", "value": "true" }
						],
						"url": {
							"raw": "{{base_url}}/reports/sales-by-customer",
							"host": ["{{base_url}}"],
							"path": ["reports", "sales-by-customer"]
						},
						"description": "## Sales By Customer Report (SP5-QA-03)\n\nGenerates an aggregated report of total purchases per customer.\n\n### Flow\n1. Fetches all customers from customer-service\n2. Calls sales-service in parallel (`Promise.all`) for each customer\n3. Filters out customers with no purchases (`total_purchases > 0`)\n\n### Prerequisites\n- **customer-service** must be running on port 3004\n- **sales-service** must be running on port 3005\n\n### Response\n- **200 OK** — Array of customers with their total purchases\n- Returns `[]` if no customers have purchases"
					},
					"response": [
						{
							"name": "200 — Report With Data",
							"originalRequest": {
								"method": "GET",
								"header": [
									{ "key": "X-Internal", "value": "true" }
								],
								"url": {
									"raw": "{{base_url}}/reports/sales-by-customer",
									"host": ["{{base_url}}"],
									"path": ["reports", "sales-by-customer"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{ "key": "Content-Type", "value": "application/json; charset=utf-8" }
							],
							"body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"customer_id\": \"11111111\",\n      \"full_name\": \"María López\",\n      \"total_purchases\": 45000.00\n    },\n    {\n      \"customer_id\": \"22222222\",\n      \"full_name\": \"Carlos Ruiz\",\n      \"total_purchases\": 12000.00\n    }\n  ],\n  \"error\": null\n}"
						},
